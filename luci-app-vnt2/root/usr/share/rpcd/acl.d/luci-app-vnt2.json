{
	"luci-app-vnt2": {
		"description": "Grant access to LuCI app VNT2",
		"read": {
			"uci": ["vnt2"],
			"file": {
				"/usr/share/vnt2/vnt2_api.sh": ["exec"],
				"/usr/bin/vnt2_ctrl": ["exec"],
				"/usr/bin/vnt2_cli": ["exec"],
				"/usr/bin/vnts2": ["exec"]
			},
			"ubus": {
				"service": ["list"],
				"luci": ["getInitList", "getLocaltime"]
			}
		},
		"write": {
			"uci": ["vnt2"],
			"file": {
				"/usr/share/vnt2/vnt2_api.sh": ["exec"]
			},
			"ubus": {
				"luci": ["setInitAction"]
			}
		}
	}
}
