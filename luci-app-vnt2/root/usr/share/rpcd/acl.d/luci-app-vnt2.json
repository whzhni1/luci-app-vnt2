{
  "luci-app-vnt2": {
    "description": "Grant access to VNT2 management",
    "read": {
      "ubus": {
        "luci.vnt2": [
          "list_instances",
          "list_configs",
          "read_config",
          "read_template",
          "get_template_fields",
          "get_instance_status",
          "get_ctrl_info",
          "get_log",
          "get_system_info",
          "check_binaries",
          "get_settings",
          "get_upstream_version",
          "get_enabled",
          "get_cpu_ticks",
          "get_update_status",
          "get_download_status"
        ]
      },
      "uci": {
        "vnt2": ["read"]
      },
      "file": {
        "/etc/vnt2_config/*": ["read"],
        "/var/log/vnt2/*":    ["read"],
        "/usr/bin/*":         ["read", "exec"]
      }
    },
    "write": {
      "ubus": {
        "luci.vnt2": [
          "save_config",
          "delete_config",
          "start_instance",
          "stop_instance",
          "restart_instance",
          "clear_log",
          "save_settings",
          "do_update",
          "set_enabled",
          "rebuild_firewall"
        ]
      },
      "uci": {
        "vnt2": ["write"]
      },
      "file": {
        "/etc/vnt2_config/*": ["read", "write"],
        "/var/log/vnt2/*":    ["read", "write"],
        "/usr/bin/*":         ["read", "write", "exec"]
      }
    }
  }
}