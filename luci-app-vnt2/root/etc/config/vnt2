config vnt2 'global'
	option bin_path '/usr/bin'
	option config_path '/etc/vnt2_config'
	option arch '0'
	option mirror 'github'
	option auto_update '0'
	option update_interval '7'
	option upx_compressed '0'
	option respawn_threshold '3600'
	option respawn_timeout '5'
	option respawn_retry '5'
    option log_max_kb '300'
	option fw_vnt_to_lan '1'
	option fw_lan_to_vnt '1'
	option fw_vnt_to_wan '0'
	option fw_wan_to_vnt '0'
	option fw_vnt_web '0'
	option fw_vnts_web '0'
