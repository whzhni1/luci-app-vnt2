# [string] 必填 网络编号，相同编号的设备组成同一虚拟局域网
network_code = ""

# [array] 必填 服务器地址列表，支持 quic/tcp/wss/dynamic 协议
# 示例: quic://1.2.3.4:29872
server = []

# [string] 自定义虚拟 IP 地址，留空自动分配
# 示例: 10.26.0.2
ip = ""

# [bool] 启用 QUIC 优化传输，开启后几乎不丢包但延迟可能波动
rtx = false

# [bool] 启用 FEC 前向纠错，损失一定带宽来提升网络稳定性
fec = false

# [bool] 启用 LZ4 数据压缩，适合带宽受限环境
compress = false

# [bool] 关闭 P2P 打洞，只通过服务器中转，网络受限时使用
no_punch = false

# [array] 入栈监听网段，格式: CIDR,目标虚拟IP，用于点对网
# 示例: 192.168.0.0/24,10.26.0.2
input = []

# [array] 出栈允许网段，格式: CIDR，0.0.0.0/0 表示全部允许
# 示例: 0.0.0.0/0
output = []

# [bool] 关闭内置子网 NAT，关闭后需配置系统网卡转发，性能更好
no_nat = false

# [bool] 禁用 TUN 虚拟网卡，禁用后只能充当流量出口或端口映射
no_tun = false

# [string] 虚拟网卡名称，留空使用默认
tun_name = ""

# [array] 端口映射规则，格式: 协议://本地监听地址-目标虚拟IP-目标映射地址
# 示例: tcp://0.0.0.0:81-10.0.0.2-10.0.0.2:80
port_mapping = []

# [bool] 允许本设备作为端口映射出口，开启后其他设备可将本设备作为跳板
allow_mapping = false

# [string] 设备名称，留空默认读取主机名
device_name = ""

# [string] 设备唯一 ID，留空自动生成，不同设备不能相同
device_id = ""

# [string] 组网加密密码，留空不加密
password = ""

# [select] 证书校验方式
# 选项: skip, standard, finger
cert_mode = "skip"

# [int] MTU 值设置，默认 1400
mtu = 1400

# [int] 控制服务 TCP 端口，设置 0 禁用，默认 11233
ctrl_port = 11233

# [array] 自定义 UDP STUN 服务器地址，不设置使用默认
# 示例: stun.chat.bilibili.com:3478
udp_stun = []

# [array] 自定义 TCP STUN 服务器地址，不设置使用默认
# 示例: stun.nextcloud.com:443
tcp_stun = []

# [string] Web 管理界面监听地址，填写后可使用 vnt2_web 启动
# 示例: 0.0.0.0:8080
web_addr = ""