# [string] 必填
# zh-cn: 网络编号，相同编号的设备组成同一虚拟局域网
# en: Network code, devices with the same code form a virtual LAN
# 示例：OpenWrt
network_code = ""

# [array] 必填
# zh-cn: 服务器地址列表，支持 quic/tcp/wss/dynamic 协议
# en: Server address list, supports quic/tcp/wss/dynamic protocols
# 示例: quic://1.2.3.4:29872
server = []

# [string]
# zh-cn: 自定义虚拟 IP 地址，留空自动分配
# en: Custom virtual IP address, leave empty for auto assignment
# 示例: 10.26.0.2
ip = ""

# [bool]
# zh-cn: 启用 QUIC 优化传输，开启后几乎不丢包但延迟可能波动
# en: Enable QUIC optimized transport, nearly zero packet loss but variable latency
rtx = false

# [bool]
# zh-cn: 启用 FEC 前向纠错，损失一定带宽来提升网络稳定性
# en: Enable FEC forward error correction, trades bandwidth for network stability
fec = false

# [bool]
# zh-cn: 启用 LZ4 数据压缩，适合带宽受限环境
# en: Enable LZ4 data compression, suitable for bandwidth-limited environments
compress = false

# [bool]
# zh-cn: 关闭 P2P 打洞，只通过服务器中转，网络受限时使用
# en: Disable P2P hole punching, relay through server only, use when network is restricted
no_punch = false

# [array]
# zh-cn: 入栈监听网段，格式: CIDR,目标虚拟IP，用于点对网
# en: Inbound listening subnet, format: CIDR,target virtual IP, for site-to-site
# 示例: 192.168.0.0/24,10.26.0.2
input = []

# [array]
# zh-cn: 出栈允许网段，格式: CIDR，0.0.0.0/0 表示全部允许
# en: Outbound allowed subnet, format: CIDR, 0.0.0.0/0 means allow all
# 示例: 0.0.0.0/0
output = []

# [bool]
# zh-cn: 关闭内置子网 NAT，关闭后需配置系统网卡转发，性能更好
# en: Disable built-in subnet NAT, requires system NIC forwarding, better performance
no_nat = false

# [bool]
# zh-cn: 禁用 TUN 虚拟网卡，禁用后只能充当流量出口或端口映射
# en: Disable TUN virtual NIC, can only act as traffic exit or port mapping after disabling
no_tun = false

# [string]
# zh-cn: 虚拟网卡名称，留空使用默认
# en: Virtual NIC name, leave empty to use default
tun_name = ""

# [array]
# zh-cn: 端口映射规则，格式: 协议://本地监听地址-目标虚拟IP-目标映射地址
# en: Port mapping rules, format: protocol://local-addr-target-virtual-ip-target-addr
# 示例: tcp://0.0.0.0:81-10.0.0.2-10.0.0.2:80
port_mapping = []

# [bool]
# zh-cn: 允许本设备作为端口映射出口，开启后其他设备可将本设备作为跳板
# en: Allow this device as port mapping exit, others can use it as a relay
allow_mapping = false

# [string]
# zh-cn: 设备名称，留空默认读取主机名
# en: Device name, leave empty to use hostname
# 示例：admin
device_name = ""

# [string]
# zh-cn: 设备唯一 ID，留空自动生成，不同设备不能相同
# en: Unique device ID, auto-generated if empty, must be unique across devices
# 示例：admin
device_id = ""

# [string]
# zh-cn: 组网加密密码，留空不加密
# en: Network encryption password, leave empty to disable encryption
# 示例：password
password = ""

# [select]
# zh-cn: 证书校验方式
# en: Certificate verification mode
# 选项: skip, standard, finger
cert_mode = "skip"

# [int]
# zh-cn: MTU 值设置，默认 1400
# en: MTU value, default 1400
mtu = 1400

# [int]
# zh-cn: 控制服务 TCP 端口，设置 0 禁用，默认 11233
# en: Control service TCP port, set 0 to disable, default 11233
ctrl_port = 11233

# [array]
# zh-cn: 自定义 UDP STUN 服务器地址，不设置使用默认
# en: Custom UDP STUN server addresses, use default if not set
# 示例: stun.chat.bilibili.com:3478
udp_stun = []

# [array]
# zh-cn: 自定义 TCP STUN 服务器地址，不设置使用默认
# en: Custom TCP STUN server addresses, use default if not set
# 示例: stun.nextcloud.com:443
tcp_stun = []

# [string]
# zh-cn: Web 管理界面监听地址，填写后可使用 vnt2_web 启动
# en: Web management listen address, enables vnt2_web startup mode when set
# 示例: 0.0.0.0:8080
web_addr = ""