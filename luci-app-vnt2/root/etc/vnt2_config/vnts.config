# [string]
# zh-cn: TCP 监听地址，不填则不启用 TCP 服务
# en: TCP listen address, leave empty to disable TCP service
# 示例: 0.0.0.0:29875
tcp_bind = ""

# [string]
# zh-cn: QUIC 监听地址，不填则不启用 QUIC 服务
# en: QUIC listen address, leave empty to disable QUIC service
# 示例: 0.0.0.0:29876
quic_bind = ""

# [string]
# zh-cn: WSS 监听地址，不填则不启用 WSS 服务
# en: WSS listen address, leave empty to disable WSS service
# 示例: 0.0.0.0:29877
ws_bind = ""

# [string] 必填
# zh-cn: 默认虚拟网段
# en: Default virtual network subnet
# 示例: 10.26.0.0/24
network = ""

# [array]
# zh-cn: 网络编号白名单，留空则不限制
# en: Network code whitelist, leave empty for no restriction
# 示例：admin
white_list = []

# [int]
# zh-cn: IP 租约时长，单位秒，默认 86400 即 24 小时
# en: IP lease duration in seconds, default 86400 (24 hours)
lease_duration = 86400

# [string]
# zh-cn: Web 管理端绑定地址，填写后可访问 WebUI
# en: Web management bind address, enables WebUI access when set
# 示例: 0.0.0.0:29878
web_bind = ""

# [string]
# zh-cn: Web 管理登录用户名
# en: Web management login username
username = "admin"

# [string]
# zh-cn: Web 管理登录密码
# en: Web management login password
password = "admin"

# [bool]
# zh-cn: 是否启用数据持久化，重启后保留 IP 分配记录
# en: Enable data persistence, retains IP assignment records after restart
persistence = true

# [string]
# zh-cn: 自定义 TLS 证书路径，不填则自动生成
# en: Custom TLS certificate path, auto-generated if empty
# 示例：/root/key.pem
cert = ""

# [string]
# zh-cn: 自定义 TLS 私钥路径，不填则自动生成
# en: Custom TLS private key path, auto-generated if empty
# 示例：/root/cert.pem
key = ""

# [string]
# zh-cn: 服务端之间通信的UDP端口，不填则不启用服务端互联
# en: UDP port for server-to-server communication, leave empty to disable
# 示例：0.0.0.0:29873
server_quic_bind = ""

# [array]
# zh-cn: 其他服务器地址列表
# en: Peer server address list
# 示例：server1.example.com:29873
peer_servers = []

# [string]
# zh-cn: 服务器验证码，用于服务器之间的身份验证
# en: Server authentication token for server-to-server verification
# 示例：your-secret-token
server_token = ""

# [section]
# zh-cn: 自定义虚拟网段映射表
# en: Custom virtual subnet mapping table
# 示例: 10.25.0.0/24
[custom_nets]